{
	"name": "dataflow_hospital_claims",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "input_hospital_claims",
						"type": "DatasetReference"
					},
					"name": "dataflow"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivecolumns"
				},
				{
					"name": "filterdataflow"
				},
				{
					"name": "selectrequiredcolumns"
				},
				{
					"name": "aggregate"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ClaimId as integer,",
				"          HospitalName as string,",
				"          PatientId as integer,",
				"          PatientName as string,",
				"          Age as short,",
				"          Gender as string,",
				"          Diagnosis as string,",
				"          ClaimAmount as integer,",
				"          AdmissionDate as date,",
				"          DischargeDate as date,",
				"          ClaimStatus as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: true,",
				"     ignoreNoFilesFound: false) ~> dataflow",
				"dataflow derive(LoadDate = currentDate(),",
				"          HospitalName = upper(HospitalName)) ~> derivecolumns",
				"derivecolumns filter(ClaimAmount > 10000) ~> filterdataflow",
				"filterdataflow select(mapColumn(",
				"          ClaimId,",
				"          HospitalName,",
				"          PatientId,",
				"          PatientName,",
				"          Age,",
				"          Gender,",
				"          Diagnosis,",
				"          Amount = ClaimAmount,",
				"          AdmissionDate,",
				"          DischargeDate,",
				"          ClaimStatus,",
				"          LoadDate",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectrequiredcolumns",
				"selectrequiredcolumns aggregate(groupBy(HospitalName),",
				"     TotalAmount = sum(Amount),",
				"          TotalCalims = count()) ~> aggregate"
			]
		}
	}
}